{
  "name": "fsw-barber-api",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node --env-file .env --no-warnings dist/server.js",
    "dev": "kill -9 $(lsof -t -i:3333) 2>/dev/null || true && tsx --env-file .env --no-warnings --watch src/server.ts",
    "build": "tsx build",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint --fix --ext ts src && prettier --write src",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --env-file .env --no-warnings src/db/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/jwt": "^10.0.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "drizzle-seed": "^0.3.1",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^6.1.0",
    "postgres": "^3.4.8",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.3.0",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "prettier": "3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "author": "Israel Jorge",
  "license": "ISC"
}
